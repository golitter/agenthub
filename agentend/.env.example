# AgentEnd 环境变量示例
# 使用方法：cp agentend/.env.example agentend/.env，然后填入实际值
#
# 其余配置（server / workspace / database / agents 等）走 agentend/config.yaml
# 此处只放 LLM 密钥与 Langfuse 追踪配置（避免硬编码到 YAML）

# ─── DeepSeek LLM（Orchestrator 必填） ───
# 从 https://platform.deepseek.com 获取 API Key
DS_MODEL=deepseek-chat
DS_BASE_URL=https://api.deepseek.com
DS_API_KEY=sk-CHANGE_ME

# ─── Langfuse Cloud 日本（东京）追踪（可选） ───
# 免费云项目地址：https://jp.cloud.langfuse.com
# 开关开启且 Public/Secret Key 都存在时才启用；云端不可用不影响业务请求
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_RELEASE=
LANGFUSE_SAMPLE_RATE=0.1

# 默认仅上报元数据；内容采集必须按类别显式开启
LANGFUSE_CAPTURE_CONTENT=false
LANGFUSE_CAPTURE_TOOL_INPUT=false
LANGFUSE_CAPTURE_TOOL_OUTPUT=false
LANGFUSE_MAX_PAYLOAD_CHARS=4000
# 逗号分隔的额外正则遮罩模式
LANGFUSE_MASK_PATTERNS=
