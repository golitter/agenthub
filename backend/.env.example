# Backend 环境变量示例
# 使用方法：cp backend/.env.example backend/.env，然后填入实际值
#
# 其余配置（MySQL / Redis / JWT / Admin / CORS 等）走 backend/configs/config.yaml
# 仅七牛云密钥通过此 .env 注入（避免硬编码到 YAML）

# ─── 七牛云对象存储（可选，留空则自动回退到本地磁盘 backend/uploads/） ───
# 用于头像、技能图标等用户上传文件
# 从 https://qiniu.com 控制台获取密钥
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=

# ─── 本机服务地址覆盖（可选） ───
# 默认读取 backend/configs/config.yaml。只有当你的 MySQL/Redis 不在 127.0.0.1 时才填写。
# 例如：Windows Docker Desktop 暴露端口后，WSL 内 go run 可能需要填 WSL 默认网关 IP。
MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DBNAME=
MYSQL_CHARSET=

REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=
